@page
@model BioDomes.Web.Areas.Identity.Pages.Account.RegisterConfirmationModel

@{
    Layout = "/Pages/Shared/_AuthLayout.cshtml";
    
    ViewData["Title"] = "Vérification du compte";
    ViewData["AuthPageTitle"] = "Confirmez votre compte";
    ViewData["AuthPageSubtitle"] = "Un e-mail de confirmation vient de vous être envoyé.";
    ViewData["AuthHeroTitle"] = "Dernière étape<br />avant le dôme.";
    ViewData["AuthHeroText"] = "Validez votre adresse e-mail pour accéder au simulateur BioDomes.";
}

<div class="auth-confirm-box">
    <div class="auth-confirm-icon auth-confirm-icon--info" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 6h16v12H4z"></path>
            <path d="m22 6-10 7L2 6"></path>
        </svg>
    </div>

    <h3 class="auth-confirm-title">Vérifiez votre boîte mail</h3>

    <p class="auth-confirm-text">
        Un lien de confirmation a été envoyé à <strong>@Model.Email</strong>.
        Cliquez sur ce lien pour activer votre compte chercheur.
    </p>

    <p class="auth-confirm-text">
        Si vous ne trouvez pas l’e-mail, pensez à vérifier vos spams ou courriers indésirables.
    </p>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="auth-status-message @(Model.IsSuccess ? "auth-status-message--success" : "auth-status-message--error")">
            @Model.StatusMessage
        </div>
    }

    <div class="auth-confirm-actions">
        <form method="post" asp-page-handler="Resend" class="auth-resend-form">
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="ReturnUrl" />

            <button type="submit"
                    class="auth-submit auth-submit--link"
                    data-cooldown-seconds="@Model.CooldownRemainingSeconds"
                    data-label-ready="Renvoyer l’e-mail de confirmation"
                    data-label-waiting="Renvoyer l’e-mail"
                    @(Model.CooldownRemainingSeconds > 0 ? "disabled" : null)>
                Renvoyer l’e-mail de confirmation
            </button>
        </form>

        <a asp-page="./Login" class="auth-secondary-link">
            Retour à la connexion
        </a>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/account/resend-email.js" asp-append-version="true"></script>
}