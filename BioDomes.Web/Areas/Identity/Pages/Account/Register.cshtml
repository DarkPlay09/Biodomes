@page
@model BioDomes.Web.Areas.Identity.Pages.Account.RegisterModel

@{
    Layout = "/Pages/Shared/_AuthLayout.cshtml";
    
    ViewData["Title"] = "Inscription";
    ViewData["AuthPageTitle"] = "Créer un compte chercheur";
    ViewData["AuthPageSubtitle"] = "Rejoignez BioDomes et commencez à concevoir vos premiers écosystèmes sous dôme.";
    ViewData["AuthHeroTitle"] = "Créez<br />votre premier biome.";
    ViewData["AuthHeroText"] = "Définissez vos conditions, ajoutez des espèces et testez la stabilité de vos environnements.";
}

<form method="post"
      asp-route-returnUrl="@Model.ReturnUrl"
      class="auth-form register-form"
      enctype="multipart/form-data"
      novalidate>

    <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

    <div class="register-avatar-block">
        <input asp-for="Input.AvatarFile"
               id="avatarInput"
               type="file"
               accept=".jpg,.jpeg,.png,.webp"
               class="register-avatar-input" />

        <label for="avatarInput" class="register-avatar-label" title="Choisir un avatar">
            <div class="register-avatar-frame">
                <img id="avatarPreview" class="register-avatar-preview" alt="Aperçu de l'avatar" hidden />

                <div id="avatarPlaceholder" class="register-avatar-placeholder" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M4 7.5A2.5 2.5 0 0 1 6.5 5H8l1-1.5h6L16 5h1.5A2.5 2.5 0 0 1 20 7.5v9A2.5 2.5 0 0 1 17.5 19h-11A2.5 2.5 0 0 1 4 16.5v-9Z"></path>
                        <circle cx="12" cy="12" r="3.5"></circle>
                        <path d="M18.5 4.5v3"></path>
                        <path d="M17 6h3"></path>
                    </svg>
                </div>
            </div>

            <span class="register-avatar-edit" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 20h9"></path>
                    <path d="M16.5 3.5a2.1 2.1 0 1 1 3 3L7 19l-4 1 1-4 12.5-12.5Z"></path>
                </svg>
            </span>
        </label>
        
        <span asp-validation-for="Input.AvatarFile" class="auth-field-error"></span>
    </div>

    <div class="register-grid">
        <div class="auth-field">
            <label asp-for="Input.UserName" class="auth-label">
                Nom d'utilisateur <span class="auth-required" aria-hidden="true">*</span>
            </label>
            <input asp-for="Input.UserName"
                   class="auth-input register-input"
                   autocomplete="username"
                   placeholder="BioExp_01" />
            <span asp-validation-for="Input.UserName" class="auth-field-error"></span>
        </div>

        <div class="auth-field">
            <label asp-for="Input.BirthDate" class="auth-label">
                Date de naissance <span class="auth-required" aria-hidden="true">*</span>
            </label>
            <input asp-for="Input.BirthDate"
                   class="auth-input register-input"
                   placeholder="jj / mm / aaaa" />
            <span asp-validation-for="Input.BirthDate" class="auth-field-error"></span>
        </div>

        <div class="auth-field register-field-full">
            <label asp-for="Input.Email" class="auth-label">
                Email professionnel <span class="auth-required" aria-hidden="true">*</span>
            </label>
            <input asp-for="Input.Email"
                   class="auth-input register-input"
                   autocomplete="email"
                   placeholder="nom@labo-recherche.fr" />
            <p class="auth-help">Un lien de vérification sera envoyé.</p>
            <span asp-validation-for="Input.Email" class="auth-field-error"></span>
        </div>

        <div class="auth-field register-field-full">
            <label asp-for="Input.ResearchOrganization" class="auth-label"></label>
            <input asp-for="Input.ResearchOrganization"
                   class="auth-input register-input"
                   placeholder="ex: CNRS, INRAE, Univ. Paris" />
            <span asp-validation-for="Input.ResearchOrganization" class="auth-field-error"></span>
        </div>

        <div class="auth-field">
            <label asp-for="Input.Password" class="auth-label">
                Mot de passe <span class="auth-required" aria-hidden="true">*</span>
            </label>
            <input asp-for="Input.Password"
                   class="auth-input register-input"
                   autocomplete="new-password"
                   placeholder="••••••••" />
            <p class="auth-help">Minimum 8 caractères requis.</p>
            <span asp-validation-for="Input.Password" class="auth-field-error"></span>
        </div>

        <div class="auth-field">
            <label asp-for="Input.ConfirmPassword" class="auth-label">
                Confirmation <span class="auth-required" aria-hidden="true">*</span>
            </label>
            <input asp-for="Input.ConfirmPassword"
                   class="auth-input register-input"
                   autocomplete="new-password"
                   placeholder="••••••••" />
            <p class="auth-help">Répétez le même mot de passe.</p>
            <span asp-validation-for="Input.ConfirmPassword" class="auth-field-error"></span>
        </div>
    </div>

    <button type="submit" class="auth-submit register-submit">
        Créer mon compte
    </button>
    
    <p class="auth-required-note">
        Les champs marqués d’un <span aria-hidden="true">*</span> sont obligatoires.
    </p>

    <p class="auth-register">
        Déjà inscrit ?
        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">Se connecter</a>
    </p>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const avatarInput = document.getElementById("avatarInput");
        const avatarPreview = document.getElementById("avatarPreview");
        const avatarPlaceholder = document.getElementById("avatarPlaceholder");

        avatarInput?.addEventListener("change", function () {
            const file = this.files && this.files[0];
            if (!file) {
                avatarPreview.hidden = true;
                avatarPreview.src = "";
                avatarPlaceholder.hidden = false;
                return;
            }

            const reader = new FileReader();
            reader.onload = function (e) {
                avatarPreview.src = e.target.result;
                avatarPreview.hidden = false;
                avatarPlaceholder.hidden = true;
            };
            reader.readAsDataURL(file);
        });
    </script>
}