@page
@model ChangePasswordModel

@{
    ViewData["Title"] = "Mot de passe";
    ViewData["DashboardTitle"] = "Mon profil";
    ViewData["DashboardSubtitle"] = "Gère la sécurité de ton compte.";
    ViewData["ActivePage"] = "Password";
}

<section class="dashboard-manage-wrapper">
    <div class="dashboard-manage-container">
        <div class="dashboard-manage-card dashboard-card">
            <header class="dashboard-manage-card__header">
                <h2>Modifier mon mot de passe</h2>
                <p>Choisis un mot de passe sécurisé pour ton compte.</p>
            </header>

            <partial name="_ManageNav" />

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="auth-status-message auth-status-message--success">
                    @Model.StatusMessage
                </div>
            }

            <form method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="auth-validation" role="alert"></div>

                <div class="auth-field">
                    <label asp-for="Input.OldPassword" class="auth-label"></label>
                    <input asp-for="Input.OldPassword"
                           class="auth-input"
                           autocomplete="current-password"
                           placeholder="Mot de passe actuel" />
                    <span asp-validation-for="Input.OldPassword" class="auth-field-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.NewPassword" class="auth-label"></label>
                    <input asp-for="Input.NewPassword"
                           class="auth-input"
                           autocomplete="new-password"
                           placeholder="Nouveau mot de passe" />
                    <span asp-validation-for="Input.NewPassword" class="auth-field-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.ConfirmPassword" class="auth-label"></label>
                    <input asp-for="Input.ConfirmPassword"
                           class="auth-input"
                           autocomplete="new-password"
                           placeholder="Confirmer le mot de passe" />
                    <span asp-validation-for="Input.ConfirmPassword" class="auth-field-error"></span>
                </div>

                <button type="submit" class="auth-submit">
                    Modifier le mot de passe
                </button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}