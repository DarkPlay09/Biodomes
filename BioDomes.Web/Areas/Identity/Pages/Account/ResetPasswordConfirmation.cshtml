@page
@model BioDomes.Web.Areas.Identity.Pages.Account.ResetPasswordConfirmationModel

@{
    Layout = "/Pages/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Mot de passe modifié";
    ViewData["AuthPageTitle"] = "Mot de passe mis à jour";
    ViewData["AuthPageSubtitle"] = "Votre nouveau mot de passe est maintenant actif.";
    ViewData["AuthHeroTitle"] = "Reprenez le contrôle<br />de votre compte<br />BioDomes.";
    ViewData["AuthHeroText"] = "Vous pouvez maintenant vous reconnecter avec votre nouveau mot de passe.";
}

<div class="auth-confirm-box">
    <div class="auth-confirm-icon auth-confirm-icon--success" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path d="M20 6 9 17l-5-5"></path>
        </svg>
    </div>

    <h3 class="auth-confirm-title">Votre mot de passe a bien été modifié.</h3>

    <p class="auth-confirm-text">
        Vous pouvez maintenant vous connecter à votre compte BioDomes avec votre nouveau mot de passe.
    </p>

    <div class="auth-confirm-actions">
        <a asp-page="./Login" class="auth-submit auth-submit--link">
            Aller à la connexion
        </a>
    </div>
</div>