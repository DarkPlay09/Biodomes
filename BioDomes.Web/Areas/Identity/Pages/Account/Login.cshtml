@page
@model BioDomes.Web.Areas.Identity.Pages.Account.LoginModel

@{
    Layout = "/Pages/Shared/_AuthLayout.cshtml";
    
    ViewData["Title"] = "Connexion";
    ViewData["AuthPageTitle"] = "Bon retour au laboratoire";
    ViewData["AuthPageSubtitle"] = "Connectez-vous pour gérer vos biomes, espèces et équipements.";
    ViewData["AuthHeroTitle"] = "Retour<br />au laboratoire.";
    ViewData["AuthHeroText"] = "Reprenez vos observations et poursuivez l’équilibre de vos écosystèmes sous dôme.";
}

<form method="post" asp-route-returnUrl="@Model.ReturnUrl" class="auth-form" novalidate>
    <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

    <div class="auth-field">
        <label asp-for="Input.Identifier" class="auth-label">
            Email ou Nom d'utilisateur <span class="auth-required" aria-hidden="true">*</span>
        </label>
        <div class="auth-input-wrap">
            <span class="auth-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21a8 8 0 1 0-16 0"></path>
                    <circle cx="12" cy="8" r="4"></circle>
                </svg>
            </span>
            <input asp-for="Input.Identifier"
                   class="auth-input"
                   autocomplete="username"
                   placeholder="chercheur@biodomes.org" />
        </div>
        <span asp-validation-for="Input.Identifier" class="auth-field-error"></span>
    </div>

    <div class="auth-field">
        <div class="auth-label-row">
            <label asp-for="Input.Password" class="auth-label">
                Mot de passe <span class="auth-required" aria-hidden="true">*</span>
            </label>
            <a asp-page="./ForgotPassword" class="auth-link auth-link--small">Oublié ?</a>
        </div>

        <div class="auth-input-wrap auth-input-wrap--password">
            <span class="auth-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="5" y="11" width="14" height="10" rx="2"></rect>
                    <path d="M8 11V8a4 4 0 1 1 8 0v3"></path>
                </svg>
            </span>
            <input asp-for="Input.Password"
                   id="passwordInput"
                   class="auth-input"
                   autocomplete="current-password"
                   placeholder="••••••••" />
            
            <button type="button"
                    id="togglePasswordButton"
                    class="auth-password-toggle"
                    aria-label="Afficher le mot de passe"
                    aria-pressed="false">
                
                <svg class="auth-password-toggle__icon auth-password-toggle__icon--show"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="2"
                     aria-hidden="true">
                    <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                </svg>
                
                <svg class="auth-password-toggle__icon auth-password-toggle__icon--hide"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="2"
                     aria-hidden="true">
                    <path d="M3 3l18 18"></path>
                    <path d="M10.58 10.58A2 2 0 0 0 12 14a2 2 0 0 0 1.42-.58"></path>
                    <path d="M9.88 4.24A10.7 10.7 0 0 1 12 4c6.5 0 10 8 10 8a17.5 17.5 0 0 1-3.05 4.36"></path>
                    <path d="M6.61 6.61A17.4 17.4 0 0 0 2 12s3.5 8 10 8a10.8 10.8 0 0 0 5.39-1.39"></path>
                </svg>
            </button>
                    
        </div>
        
        <span asp-validation-for="Input.Password" class="auth-field-error"></span>
    </div>

    <button type="submit" class="auth-submit">Se connecter</button>
    
    <p class="auth-required-note">
        Les champs marqués d’un <span aria-hidden="true">*</span> sont obligatoires.
    </p>

    <p class="auth-register">
        Nouveau chercheur ?
        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">Créer un compte</a>
    </p>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/auth-password-toggle.js" asp-append-version="true"></script>
}