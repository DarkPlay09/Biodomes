@page
@model BioDomes.Web.Areas.Identity.Pages.Account.LoginModel

@{
    Layout = "/Pages/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Connexion";
    ViewData["AuthPageTitle"] = "Bon retour parmi nous";
    ViewData["AuthPageSubtitle"] = "Accédez à votre compte de chercheur BioDomes.";
    ViewData["AuthHeroTitle"] = "Cultiver le futur,<br />un écosystème à<br />la fois.";
    ViewData["AuthHeroText"] = "Rejoignez le réseau mondial de chercheurs en biodynamie et accédez aux outils de surveillance en temps réel de vos dômes.";
}

<form method="post" asp-route-returnUrl="@Model.ReturnUrl" class="auth-form" novalidate>
    <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

    <div class="auth-field">
        <label asp-for="Input.Identifier" class="auth-label"></label>
        <div class="auth-input-wrap">
            <span class="auth-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21a8 8 0 1 0-16 0"></path>
                    <circle cx="12" cy="8" r="4"></circle>
                </svg>
            </span>
            <input asp-for="Input.Identifier"
                   class="auth-input"
                   autocomplete="username"
                   placeholder="chercheur@biodomes.org" />
        </div>
        <span asp-validation-for="Input.Identifier" class="auth-field-error"></span>
    </div>

    <div class="auth-field">
        <div class="auth-label-row">
            <label asp-for="Input.Password" class="auth-label"></label>
            <a asp-page="./ForgotPassword" class="auth-link auth-link--small">Oublié ?</a>
        </div>

        <div class="auth-input-wrap">
            <span class="auth-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="5" y="11" width="14" height="10" rx="2"></rect>
                    <path d="M8 11V8a4 4 0 1 1 8 0v3"></path>
                </svg>
            </span>
            <input asp-for="Input.Password"
                   class="auth-input"
                   autocomplete="current-password"
                   placeholder="••••••••" />
        </div>

        <p class="auth-help">Minimum 8 caractères requis.</p>
        <span asp-validation-for="Input.Password" class="auth-field-error"></span>
    </div>

    <button type="submit" class="auth-submit">Se connecter au réseau</button>

    <p class="auth-register">
        Nouveau membre ?
        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">Créer un profil</a>
    </p>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}