@page
@model BioDomes.Web.Areas.Identity.Pages.Account.ResetPasswordModel

@{
    Layout = "/Pages/Shared/_AuthLayout.cshtml";
    
    ViewData["Title"] = "Nouveau mot de passe";
    ViewData["AuthPageTitle"] = "Choisir un nouveau mot de passe";
    ViewData["AuthPageSubtitle"] = "Sécurisez l’accès à votre espace BioDomes.";
    ViewData["AuthHeroTitle"] = "Sécurisez<br />votre accès.";
    ViewData["AuthHeroText"] = "Définissez un nouveau mot de passe pour retrouver votre laboratoire et vos données.";
}

<form method="post" class="auth-form" novalidate>
    <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

    <input asp-for="Input.Code" type="hidden" />
    <input asp-for="Input.Email" type="hidden" />

    <div class="auth-field">
        <label asp-for="Input.Password" class="auth-label"></label>
        <input asp-for="Input.Password"
               class="auth-input"
               autocomplete="new-password"
               placeholder="••••••••" />
        <span asp-validation-for="Input.Password" class="auth-field-error"></span>
    </div>

    <div class="auth-field">
        <label asp-for="Input.ConfirmPassword" class="auth-label"></label>
        <input asp-for="Input.ConfirmPassword"
               class="auth-input"
               autocomplete="new-password"
               placeholder="••••••••" />
        <span asp-validation-for="Input.ConfirmPassword" class="auth-field-error"></span>
    </div>

    <button type="submit" class="auth-submit">
        Enregistrer mon nouveau mot de passe
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}