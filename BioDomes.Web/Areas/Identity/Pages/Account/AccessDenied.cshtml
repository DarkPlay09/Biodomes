@page
@model BioDomes.Web.Areas.Identity.Pages.Account.AccessDeniedModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Accès refusé - BioDomes</title>

    <link rel="stylesheet" href="~/css/pages/access-denied.css" asp-append-version="true" />
</head>

<body class="access-denied-page">
    <main class="access-denied">
        <div class="access-denied__brand">
            <img src="~/images/logo_biodomes.png" alt="Logo BioDomes" />
            <div>
                <strong>BioDomes</strong>
                <span>Système sécurisé</span>
            </div>
        </div>

        <section class="access-denied__card" aria-labelledby="accessDeniedTitle">
            <div class="access-denied__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                    <path d="M12 3L20 6.5V12C20 17 16.6 20.1 12 21C7.4 20.1 4 17 4 12V6.5L12 3Z"
                          fill="currentColor"
                          opacity="0.24" />
                    <path d="M12 8V13"
                          stroke="currentColor"
                          stroke-width="2.3"
                          stroke-linecap="round" />
                    <path d="M12 16H12.01"
                          stroke="currentColor"
                          stroke-width="2.8"
                          stroke-linecap="round" />
                </svg>

                <span>Protocole 403</span>
            </div>

            <h1 id="accessDeniedTitle">
                Accès refusé
            </h1>

            <p class="access-denied__text">
                Désolé, chercheur. Vous n'avez pas les autorisations nécessaires pour accéder
                à ce secteur restreint de la plateforme <strong>BioDomes</strong>.
            </p>

            <a asp-area=""
               asp-page="/Dashboard/Index"
               class="access-denied__button">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M12 3L20 6.5V12C20 17 16.6 20.1 12 21C7.4 20.1 4 17 4 12V6.5L12 3Z"
                          fill="currentColor" />
                </svg>

                Revenir en lieu sûr

                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M5 12H19"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round" />
                    <path d="M13 6L19 12L13 18"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round" />
                </svg>
            </a>

            <p class="access-denied__footer">
                BioDomes Systematic Administration
            </p>
        </section>

        <div class="access-denied__watermark" aria-hidden="true">
            Restricted access
        </div>
    </main>
</body>
</html>