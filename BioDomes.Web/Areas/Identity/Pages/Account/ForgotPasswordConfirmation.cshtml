@page
@model BioDomes.Web.Areas.Identity.Pages.Account.ForgotPasswordConfirmationModel

@{
    Layout = "/Pages/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "E-mail de réinitialisation";
    ViewData["AuthPageTitle"] = "Consultez votre boîte mail";
    ViewData["AuthPageSubtitle"] = "Si un compte correspond à cette adresse, un lien de réinitialisation a été envoyé.";
    ViewData["AuthHeroTitle"] = "Retrouvez<br />votre accès.";
    ViewData["AuthHeroText"] = "Un lien sécurisé vous permet de choisir un nouveau mot de passe pour votre espace BioDomes.";
}

<div class="auth-confirm-box">
    <div class="auth-confirm-icon auth-confirm-icon--info" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 6h16v12H4z"></path>
            <path d="m22 6-10 7L2 6"></path>
        </svg>
    </div>

    <h3 class="auth-confirm-title">Demande prise en compte</h3>

    <p class="auth-confirm-text">
        Si un compte BioDomes correspond à <strong>@Model.Email</strong>,
        un lien de réinitialisation vient d’être envoyé.
    </p>

    <p class="auth-confirm-text">
        Ouvrez cet e-mail pour définir un nouveau mot de passe et retrouver l’accès
        à votre espace de recherche.
    </p>

    <p class="auth-confirm-text">
        Si vous ne voyez rien arriver, vérifiez aussi vos spams ou courriers indésirables.
    </p>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="auth-status-message @(Model.IsSuccess ? "auth-status-message--success" : "auth-status-message--error")">
            @Model.StatusMessage
        </div>
    }

    <div class="auth-confirm-actions">
        <form method="post" asp-page-handler="Resend" class="auth-resend-form">
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="ReturnUrl" />

            <button type="submit"
                    class="auth-submit auth-submit--link"
                    data-cooldown-seconds="@Model.CooldownRemainingSeconds"
                    data-label-ready="Renvoyer le lien"
                    data-label-waiting="Veuillez patienter"
                    @(Model.CooldownRemainingSeconds > 0 ? "disabled" : null)>
                Renvoyer le lien
            </button>
        </form>

        <a asp-page="./Login" class="auth-secondary-link">
            Retour à la connexion
        </a>
    </div>
</div>

@section Scripts {
    <script src="~/js/auth-resend.js" asp-append-version="true"></script>
}