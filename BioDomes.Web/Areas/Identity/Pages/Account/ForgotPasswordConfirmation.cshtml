@page
@model BioDomes.Web.Areas.Identity.Pages.Account.ForgotPasswordConfirmationModel

@{
    Layout = "/Pages/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Vérifiez votre boîte mail";
    ViewData["AuthPageTitle"] = "Demande enregistrée";
    ViewData["AuthPageSubtitle"] = "Un e-mail de réinitialisation peut vous avoir été envoyé.";
    ViewData["AuthHeroTitle"] = "Retrouvez l'accès<br />à votre espace<br />BioDomes.";
    ViewData["AuthHeroText"] = "Utilisez le lien reçu par e-mail pour choisir un nouveau mot de passe.";
}

<div class="auth-confirm-box">
    <div class="auth-confirm-icon auth-confirm-icon--info" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 6h16v12H4z"></path>
            <path d="m22 6-10 7L2 6"></path>
        </svg>
    </div>

    <h3 class="auth-confirm-title">Vérifiez votre boîte mail</h3>

    <p class="auth-confirm-text">
        Si un compte BioDomes correspond à <strong>@Model.Email</strong>,
        un lien de réinitialisation a été envoyé.
    </p>

    <p class="auth-confirm-text">
        Pensez aussi à vérifier vos spams ou courriers indésirables.
    </p>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="auth-status-message @(Model.IsSuccess ? "auth-status-message--success" : "auth-status-message--error")">
            @Model.StatusMessage
        </div>
    }

    <div class="auth-confirm-actions">
        <form method="post" asp-page-handler="Resend" class="auth-resend-form">
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="ReturnUrl" />

            <button type="submit"
                    class="auth-submit auth-submit--link"
                    data-cooldown-seconds="@Model.CooldownRemainingSeconds"
                    data-label-ready="Renvoyer l’e-mail de réinitialisation"
                    data-label-waiting="Renvoyer l’e-mail"
                    @(Model.CooldownRemainingSeconds > 0 ? "disabled" : null)>
                Renvoyer l’e-mail de réinitialisation
            </button>
        </form>

        <a asp-page="./Login" class="auth-secondary-link">
            Retour à la connexion
        </a>
    </div>
</div>

@section Scripts {
    <script src="~/js/auth-resend.js" asp-append-version="true"></script>
}