@page
@model BioDomes.Web.Areas.Identity.Pages.Account.ForgotPasswordModel

@{
    Layout = "/Pages/Shared/_AuthLayout.cshtml";

    ViewData["Title"] = "Mot de passe oublié";
    ViewData["AuthPageTitle"] = "Réinitialiser mon accès";
    ViewData["AuthPageSubtitle"] = "Indiquez l’adresse liée à votre compte BioDomes.";
    ViewData["AuthHeroTitle"] = "Accès<br />au laboratoire.";
    ViewData["AuthHeroText"] = "Recevez un lien sécurisé pour reprendre vos recherches sans perdre vos données.";
}

<form method="post" asp-route-returnUrl="@Model.ReturnUrl" class="auth-form" novalidate>
    <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

    <div class="auth-field">
        <label asp-for="Input.Email" class="auth-label">
            Email professionnel <span class="auth-required" aria-hidden="true">*</span>
        </label>
        <div class="auth-input-wrap">
            <span class="auth-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 6h16v12H4z"></path>
                    <path d="m4 7 8 6 8-6"></path>
                </svg>
            </span>
            <input asp-for="Input.Email"
                   class="auth-input"
                   autocomplete="email"
                   placeholder="nom@labo-recherche.fr"/>
            <span asp-validation-for="Input.Email" class="auth-field-error"></span>
        </div>
    </div>

    <p class="auth-note">
        Si un compte existe avec cette adresse, un e-mail de réinitialisation sera envoyé.
    </p>

    <button type="submit" class="auth-submit">
        Envoyer le lien de réinitialisation
    </button>

    <p class="auth-required-note">
        Les champs marqués d’un <span aria-hidden="true">*</span> sont obligatoires.
    </p>

    <p class="auth-register">
        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">
            Retour à la connexion
        </a>
    </p>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}