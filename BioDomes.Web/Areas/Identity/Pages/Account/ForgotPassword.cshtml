@page
@model BioDomes.Web.Areas.Identity.Pages.Account.ForgotPasswordModel

@{
    Layout = "/Pages/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Mot de passe oublié";
    ViewData["AuthPageTitle"] = "Mot de passe oublié";
    ViewData["AuthPageSubtitle"] = "Recevez un lien pour réinitialiser votre mot de passe.";
    ViewData["AuthHeroTitle"] = "Retrouvez l'accès<br />à votre espace<br />BioDomes.";
    ViewData["AuthHeroText"] = "Entrez votre adresse e-mail pour recevoir un lien de réinitialisation.";
}

<form method="post" asp-route-returnUrl="@Model.ReturnUrl" class="auth-form" novalidate>
    <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

    <div class="auth-field">
        <label asp-for="Input.Email" class="auth-label"></label>
        <input asp-for="Input.Email"
               class="auth-input"
               autocomplete="email"
               placeholder="nom@labo-recherche.fr" />
        <span asp-validation-for="Input.Email" class="auth-field-error"></span>
    </div>

    <p class="auth-note">
        Nous vous enverrons un e-mail contenant un lien sécurisé pour choisir un nouveau mot de passe.
    </p>

    <button type="submit" class="auth-submit">
        Envoyer le lien de réinitialisation
    </button>

    <p class="auth-register">
        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="auth-link">
            Retour à la connexion
        </a>
    </p>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}