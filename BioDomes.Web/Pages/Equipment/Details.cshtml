@page "/equipment/details/{slug}"
@model BioDomes.Web.Pages.Equipment.DetailsModel

@{
    var isAuthenticated = User.Identity?.IsAuthenticated == true;

    Layout = isAuthenticated
        ? "/Pages/Shared/_DashboardLayout.cshtml"
        : "/Pages/Shared/_Layout.cshtml";

    ViewData["Title"] = Model.EquipmentDetails.Name;

    if (isAuthenticated)
    {
        ViewData["DashboardTitle"] = "Fiche équipement détaillée";
        ViewData["DashboardSubtitle"] = "Consulte les informations principales de cet équipement.";
    }

    var request = ViewContext.HttpContext.Request;
    var currentUrl = $"{request.PathBase}{request.Path}{request.QueryString}";

    var imagePath = Model.EquipmentDetails.ImagePath;

    if (!string.IsNullOrWhiteSpace(imagePath) && imagePath.StartsWith("/"))
    {
        imagePath = "~" + imagePath;
    }

    var imageSrc = string.IsNullOrWhiteSpace(imagePath)
        ? Url.Content("~/images/logo_biodomes.png")
        : Url.Content(imagePath);

    var usageCount = Model.EquipmentDetails.ImpactedBiomesCount;
    var biomeWord = usageCount > 1 ? "biomes" : "biome";
}

<section class="species-details">
    <nav class="species-details-breadcrumb" aria-label="Fil d'Ariane">
        <a asp-page="./Index">Équipements</a>
        <span>›</span>
        <strong>@Model.EquipmentDetails.Name</strong>
    </nav>

    <div class="species-details-layout @(isAuthenticated ? "" : "species-details--public")">
        <div class="species-details-media">
            <article class="species-details-image-card">
                <img src="@imageSrc"
                     alt="Image de @Model.EquipmentDetails.Name" />

                <div class="species-details-badges">
                    <span class="species-details-badge @Model.EquipmentDetails.VisibilityCssClass">
                        @Model.EquipmentDetails.VisibilityLabel
                    </span>
                </div>
            </article>

            <a href="@Model.SafeReturnUrl" class="species-details-back">
                Retour
            </a>
        </div>

        <article class="species-details-content">
            <header class="species-details-header">
                <h2>@Model.EquipmentDetails.Name</h2>
            </header>

            <div class="equipement-details-stats">
                <div class="species-details-stat">
                    <img class="species-details-stat__icon" src="~/images/equipment/icons/produces.png" alt="Icon produit" />
                    <small>Produit</small>
                    <strong>@Model.EquipmentDetails.ProducedElementLabel</strong>
                </div>

                <div class="species-details-stat">
                    <img class="species-details-stat__icon" src="~/images/equipment/icons/consumes.png" alt="Icon consomme" />
                    <small>Consomme</small>
                    <strong>@Model.EquipmentDetails.ConsumedElementLabel</strong>
                </div>

                <div class="species-details-stat">
                    <img class="species-details-stat__icon" src="~/images/species/icons/visibility.png" alt="Icon visibilité" />
                    <small>Visibilité</small>
                    <strong>@Model.EquipmentDetails.VisibilityLabel</strong>
                </div>

                <div class="species-details-stat">
                    <img class="species-details-stat__icon" src="~/images/species/icons/user.png" alt="Icon créateur" />
                    <small>Créateur</small>
                    <strong>@Model.EquipmentDetails.OwnerName</strong>
                </div>
            </div>
            
            @if (Model.EquipmentDetails.CanManage)
            {
                <div class="species-details-actions">
                    <a asp-page="./Edit"
                       asp-route-slug="@Model.EquipmentDetails.Slug"
                       asp-route-returnUrl="@currentUrl"
                       class="species-details-edit-button">
                        Modifier la fiche
                    </a>

                    <form id="deleteEntityForm"
                          method="post"
                          asp-page-handler="Delete"
                          asp-route-slug="@Model.EquipmentDetails.Slug"
                          asp-route-returnUrl="@Model.SafeReturnUrl"
                          class="species-details-delete-form">
                        @if (Model.EquipmentDetails.CanManage && Model.EquipmentDetails.ImpactedBiomesCount == 0)
                        {
                            <div class="custom-modal" id="deleteConfirmModal" aria-hidden="true">
                                <div class="custom-modal__overlay" data-close-delete-modal></div>

                                <div class="custom-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
                                    <button type="button"
                                            class="custom-modal__close"
                                            aria-label="Fermer"
                                            data-close-delete-modal>
                                        ×
                                    </button>

                                    <div class="custom-modal__icon">
                                        !
                                    </div>

                                    <h3 class="custom-modal__title" id="deleteModalTitle">
                                        Confirmer la suppression
                                    </h3>

                                    <p class="custom-modal__text">
                                        Voulez-vous vraiment supprimer cet équipement ?
                                        Cette action est <strong>définitive</strong>.
                                    </p>

                                    <div class="custom-modal__actions">
                                        <button type="button"
                                                class="custom-modal__button custom-modal__button--secondary"
                                                data-close-delete-modal>
                                            Annuler
                                        </button>

                                        <button type="button"
                                                class="custom-modal__button custom-modal__button--danger"
                                                id="confirmDeleteButton">
                                            Oui, supprimer
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </form>
                </div>
            }
        </article>
    </div>
    
    <div class="custom-modal" id="deleteConfirmModal" aria-hidden="true">
        <div class="custom-modal__overlay" data-close-delete-modal></div>

        <div class="custom-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
            <button type="button"
                    class="custom-modal__close"
                    aria-label="Fermer"
                    data-close-delete-modal>
                ×
            </button>

            <div class="custom-modal__icon">
                !
            </div>

            <h3 class="custom-modal__title" id="deleteModalTitle">
                Confirmer la suppression
            </h3>

            <p class="custom-modal__text">
                Voulez-vous vraiment supprimer cet équipement ?
                Cette action est <strong>définitive</strong>.
            </p>

            <div class="custom-modal__actions">
                <button type="button"
                        class="custom-modal__button custom-modal__button--secondary"
                        data-close-delete-modal>
                    Annuler
                </button>

                <button type="button"
                        class="custom-modal__button custom-modal__button--danger"
                        id="confirmDeleteButton">
                    Oui, supprimer
                </button>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @if (Model.EquipmentDetails.CanManage && Model.EquipmentDetails.ImpactedBiomesCount == 0)
    {
        <script src="~/js/shared/confirm-delete-modal.js" asp-append-version="true"></script>
    }
}