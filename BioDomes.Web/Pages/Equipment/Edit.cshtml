@page "/equipment/{slug}"
@model BioDomes.Web.Pages.Equipment.EditModel

<div class="layout-width">
    <section class="entity-form-page">
        <div class="entity-form-page__intro">
            <span class="hero-badge">
                <span class="hero-badge-dot"></span>
                Modification
            </span>
            <h1 class="hero-title">Modifier un equipement</h1>
        </div>

        <div class="entity-form-card">
            <form method="post" enctype="multipart/form-data" class="entity-form">
                <div asp-validation-summary="ModelOnly" class="entity-form__summary"></div>

                <partial name="Equipment/_EquipmentForm" model="new EquipmentFormViewModel
                         {
                             Input = Model.Input,
                             ResourceOptions = Model.ResourceOptions,
                             CurrentImagePath = Model.CurrentImagePath,
                             CurrentImageFileName = string.IsNullOrWhiteSpace(Model.CurrentImagePath)
                                 ? null
                                 : System.IO.Path.GetFileName(Model.CurrentImagePath)
                 }"/>

                <div class="entity-form__actions">
                    <a asp-page="/Equipment/Index" class="entity-form__back">Retour</a>
                    <button type="submit" class="action-button">Enregistrer</button>
                </div>
            </form>
        </div>
    </section>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/entity-file-upload.js" asp-append-version="true"></script>

}
