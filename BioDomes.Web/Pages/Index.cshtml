@page
@model IndexModel
@{
    ViewData["Title"] = "Accueil";
}

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="dashboard-toast dashboard-toast--success" data-dashboard-toast>
        <div class="dashboard-toast__icon">✓</div>

        <div class="dashboard-toast__content">
            <strong>Succès</strong>
            <p>@successMessage</p>
        </div>

        <button type="button"
                class="dashboard-toast__close"
                data-dashboard-toast-close
                aria-label="Fermer la notification">
            ×
        </button>
    </div>
}

<section class="hero-section">
    <div class="hero-wrapper">
        <div class="hero-text">
            <div class="hero-badge">
                <span class="hero-badge-dot"></span>
                <span>Phase Alpha : Accès anticipé</span>
            </div>

            <h1 class="hero-title">
                BioDomes – <span class="hero-title-accent">Terrarium Zero</span>
            </h1>

            <p class="hero-description">
                Plongez dans une simulation de biome post-apocalyptique. Gérez des écosystèmes complexes et assurez la survie de la biodiversité face à l'extinction globale.
            </p>

            <div class="hero-actions">
                <a class="button button-primary" href="#">Commencer l'aventure</a>
                <a class="button button-secondary" href="#">En savoir plus</a>
            </div>
        </div>

        <div class="hero-visual">
            <div class="hero-image-frame">
                <img src="~/images/home_hero_image.png" alt="Home Hero Image" class="hero-image"/>
            </div>

            <div class="hero-stat-card">
                <p class="hero-stat-label">Stabilité écosystémique</p>
                <p class="hero-stat-value">94.2%</p>
            </div>
        </div>
    </div>
</section>

<section class="final-cta-section">
    <div class="final-cta-glow"></div>

    <div class="final-cta-wrapper">
        <h2 class="final-cta-title">
            Devenez le gardien de la biodiversité de demain.
        </h2>

        <p class="final-cta-text">
            Rejoignez des milliers de scientifiques et passionnés dans la mission de
            préservation la plus ambitieuse du 21ème siècle.
        </p>

        <div class="final-cta-actions">
            <a class="final-cta-button final-cta-button-main" href="#">
                Créer mon laboratoire gratuit
            </a>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/dashboard-toast.js" asp-append-version="true"></script>
}