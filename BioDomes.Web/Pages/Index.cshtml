@page
@model IndexModel

@{
    ViewData["Title"] = "Accueil";
}

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="dashboard-toast dashboard-toast--success" data-dashboard-toast>
        <div class="dashboard-toast__icon">✓</div>

        <div class="dashboard-toast__content">
            <strong>Succès</strong>
            <p>@successMessage</p>
        </div>

        <button type="button"
                class="dashboard-toast__close"
                data-dashboard-toast-close
                aria-label="Fermer la notification">
            ×
        </button>
    </div>
}

<section class="hero-section">
    <div class="hero-wrapper">
        <div class="hero-text">
            <div class="hero-badge">
                <span class="hero-badge-pulse">
                    <span class="hero-badge-ping"></span>
                    <span class="hero-badge-dot"></span>
                </span>

                <span>Accès anticipé</span>
            </div>

            <h1 class="hero-title">
                BioDomes – <span class="hero-title-accent">Terrarium Zero</span>
            </h1>

            <p class="hero-description">
                Créez des biomes capables de survivre dans des conditions postapocalyptiques.
                Ajustez la température, contrôlez l’humidité, introduisez des espèces et utilisez
                des équipements pour maintenir un écosystème viable.
            </p>

            <div class="hero-actions">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="button button-primary" asp-page="/Dashboard/Index">
                        Accéder à mon laboratoire
                    </a>
                }
                else
                {
                    <a class="button button-primary" asp-area="Identity" asp-page="/Account/Register">
                        Créer mon profil de chercheur
                    </a>
                }

                <a class="button button-secondary" href="#laboratoire">
                    Découvrir le simulateur
                </a>
            </div>
        </div>

        <div class="hero-visual">
            <div class="hero-image-frame">
                <img src="~/images/home/landscape.jpg"
                     alt="Paysage naturel utilisé pour illustrer un biome expérimental"
                     class="hero-image" />
            </div>
        </div>
    </div>
</section>

<section id="laboratoire" class="lab-section">
    <div class="home-container">
        <header class="section-heading section-heading--center">
            <h2>Un simulateur de biomes sous dôme</h2>
            <div class="section-heading__line"></div>

            <p>
                Terrarium Zero permet aux chercheurs de tester différents scénarios climatiques,
                d’associer des espèces à un environnement et d’observer si l’équilibre du biome
                peut être maintenu durablement.
            </p>
        </header>

        <div class="lab-grid">
            <article class="lab-card">
                <div class="lab-card__icon">
                    <img src="~/images/home/icons/brightness.png"
                         alt=""
                         aria-hidden="true" />
                </div>

                <h3>Conditions du biome</h3>

                <p>
                    Définissez les paramètres essentiels du dôme, comme la température
                    et l’humidité absolue, afin d’évaluer si le biome est optimal, instable
                    ou critique.
                </p>
            </article>

            <article class="lab-card">
                <div class="lab-card__icon">
                    <img src="~/images/home/icons/thermometer_white.png"
                         alt=""
                         aria-hidden="true" />
                </div>

                <h3>Équilibre environnemental</h3>

                <p>
                    Surveillez les limites climatiques du biome et adaptez vos choix pour
                    éviter que l’environnement ne devienne trop hostile pour les espèces.
                </p>
            </article>

            <article class="lab-card">
                <div class="lab-card__icon">
                    <img src="~/images/home/icons/adn.png"
                         alt=""
                         aria-hidden="true" />
                </div>

                <h3>Réseaux trophiques</h3>

                <p>
                    Composez un écosystème cohérent en ajoutant des espèces, des individus
                    et des ressources pour que chaque organisme puisse trouver sa place.
                </p>
            </article>
        </div>
    </div>
</section>

<section class="creators-section">
    <div class="home-container creators-layout">
        <div class="creators-text">
            <p class="section-eyebrow">Studio à l’origine du projet</p>

            <h2>Laudot Solutions</h2>

            <p>
                Laudot Solutions imagine Terrarium Zero comme une plateforme de recherche
                en ligne dédiée à la simulation de biomes extrêmes. L’objectif est de fournir
                aux chercheurs un outil clair pour créer, comparer et améliorer des écosystèmes
                artificiels.
            </p>

            <p>
                Avec BioDomes, le studio met l’accent sur la viabilité des environnements :
                chaque biome doit tenir compte de ses conditions climatiques, des espèces
                présentes, des équipements disponibles et de l’équilibre alimentaire entre
                les organismes.
            </p>
        </div>

        <div class="creators-visuals" aria-hidden="true">
            <div class="creators-visual-card creators-visual-card--primary">
                <img src="~/images/home/iguana.jpg"
                     alt=""
                     aria-hidden="true"
                     class="creators-visual-card__image" />
            </div>

            <div class="creators-visual-card creators-visual-card--accent">
                <img src="~/images/home/biologist-woman.jpg"
                     alt=""
                     aria-hidden="true"
                     class="creators-visual-card__image" />
            </div>
        </div>
    </div>
</section>

<section class="home-biomes-section">
    <div class="home-container">
        <header class="section-heading section-heading--split">
            <div>
                <h2>Biomes équilibrés les plus diversifiés</h2>
                <p>
                    Consultez les dômes les plus prometteurs : ceux qui combinent
                    stabilité, conditions maîtrisées et forte diversité d’espèces.
                </p>
            </div>
        </header>

        @if (Model.BestBiomes.Count == 0)
        {
            <div class="home-biome-empty">
                <h3>Aucun biome équilibré à afficher</h3>
                <p>
                    Les biomes apparaîtront ici dès qu’ils atteindront un état viable
                    avec des espèces associées et un bon niveau de diversité.
                </p>
            </div>
        }
        else
        {
            <div class="home-biome-grid">
                @foreach (var biome in Model.BestBiomes)
                {
                    var stateClass = biome.State switch
                    {
                        "Optimal" => "home-biome-card__state--optimal",
                        "Instable" => "home-biome-card__state--unstable",
                        "Critique" => "home-biome-card__state--critical",
                        _ => "home-biome-card__state--neutral"
                    };
                    
                    <article class="home-biome-card">
                        <div class="home-biome-card__header">
                            <div>
                                <h3>@biome.Name</h3>
                            </div>

                            <strong>@biome.StabilityScore.ToString()/100</strong>
                        </div>

                        <div class="home-biome-card__metrics">
                            <div>
                                <img src="~/images/home/icons/thermometer_green.png"
                                     alt=""
                                     aria-hidden="true"
                                     class="home-biome-card__icon" />
                                <p>@biome.Temperature.ToString("0.#")°C</p>
                            </div>

                            <div>
                                <img src="~/images/home/icons/humidity.png"
                                     alt=""
                                     aria-hidden="true"
                                     class="home-biome-card__icon" />
                                <p>@biome.AbsoluteHumidity.ToString("0.#") g/m³</p>
                            </div>

                            <div>
                                <img src="~/images/home/icons/paws.png"
                                     alt=""
                                     aria-hidden="true"
                                     class="home-biome-card__icon" />
                                <p>@biome.SpeciesCount espèces</p>
                            </div>

                            <div>
                                <img src="~/images/home/icons/beaker.png"
                                     alt=""
                                     aria-hidden="true"
                                     class="home-biome-card__icon" />
                                <p>@biome.EquipmentCount équipements</p>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </div>
</section>

<section class="final-cta-section">
    <div class="final-cta-glow"></div>

    <div class="final-cta-wrapper">
        <h2 class="final-cta-title">
            Construisez votre premier biome viable.
        </h2>

        <p class="final-cta-text">
            Expérimentez, observez et améliorez vos écosystèmes sous dôme.
            Chaque choix compte : climat, espèces, équipements et équilibre alimentaire.
        </p>

        <div class="final-cta-actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="final-cta-button final-cta-button-main" asp-page="/Dashboard/Index">
                    Ouvrir mon espace de recherche
                </a>
            }
            else
            {
                <a class="final-cta-button final-cta-button-main" asp-area="Identity" asp-page="/Account/Register">
                    Rejoindre Terrarium Zero
                </a>
            }

            <a class="final-cta-button final-cta-button-secondary" href="#laboratoire">
                Voir les principes du simulateur
            </a>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/dashboard-toast.js" asp-append-version="true"></script>
}