@page "/Error/{statusCode?}"
@model ErrorModel

@{
    Layout = null;
    ViewData["Title"] = Model.StatusTitle;
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.StatusTitle - BioDomes</title>
    <link rel="icon" type="image/png" href="~/images/logo_biodomes.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="error-status-page @Model.StatusCssClass">
<main class="error-status">
    <div class="error-status__brand">
        <img src="~/images/logo_biodomes.png" alt="" aria-hidden="true" />
        <div>
            <strong>BioDomes</strong>
            <span>Système sécurisé</span>
        </div>
    </div>

    <section class="error-status__card" aria-labelledby="errorStatusTitle">
        <div class="error-status__icon">
            <img src="~/images/error/error-403.png"
                 alt=""
                 aria-hidden="true"
                 class="error-status__icon-image" />

            <span>@Model.StatusLabel</span>
        </div>

        <h1 id="errorStatusTitle">@Model.StatusTitle</h1>

        <p class="error-status__text">
            @Model.StatusText
        </p>

        <a href="/dashboard" class="error-status__button">
            Retour au tableau de bord
            <span aria-hidden="true">→</span>
        </a>

        @if (Model.ShowRequestId)
        {
            <p class="error-status__footer">
                Request ID : @Model.RequestId
            </p>
        }
    </section>

    <div class="error-status__watermark" aria-hidden="true">
        BioDomes
    </div>
</main>
</body>
</html>