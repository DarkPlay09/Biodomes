@page "/species/add"
@model BioDomes.Web.Pages.Species.AddModel

@{
    Layout = "/Pages/Shared/_DashboardLayout.cshtml";

    ViewData["Title"] = "Ajouter une espèce";
    ViewData["DashboardTitle"] = "Ajouter une espèce";
    ViewData["DashboardSubtitle"] = "Ajoute une nouvelle espèce au catalogue BioDomes.";
}

<div class="layout-width">
    <section class="entity-form-page">
        <div class="entity-form-page__intro">
            <span class="hero-badge">
                <span class="hero-badge-dot"></span>
                Nouvelle entrée
            </span>
            <h1 class="hero-title">Ajouter une espèce</h1>
            <p class="entity-form-page__text">
                Ajoute une nouvelle espèce à l'écosystème BioDomes avec ses caractéristiques et son visuel.
            </p>
        </div>

        <div class="entity-form-card">
            <form method="post" enctype="multipart/form-data" class="entity-form">
                <input type="hidden" asp-for="ReturnUrl" />
                
                <div asp-validation-summary="ModelOnly" class="entity-form__summary"></div>

                <partial name="Species/_SpeciesForm" model="new SpeciesFormViewModel { Input = Model.Input, ClassificationOptions = Model.ClassificationOptions, DietOptions = Model.DietOptions }"/>

                <div class="entity-form__actions">
                    <a href="@Model.SafeReturnUrl" class="entity-form__back">Retour</a>
                    <button type="submit" class="action-button">Créer l'espèce</button>
                </div>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/entity-file-upload.js" asp-append-version="true"></script>
}