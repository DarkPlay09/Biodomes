@page "/species/add"
@model BioDomes.Web.Pages.Species.AddModel

<h1>Ajouter une espèce</h1>

<form method="post">
    <div>
        <label asp-for="Input.Name"></label>
        <input asp-for="Input.Name" />
        <span asp-validation-for="Input.Name"></span>
    </div>

    <div>
        <label asp-for="Input.Type"></label>
        <select asp-for="Input.Type" asp-items="Model.ClassificationOptions"></select>
        <span asp-validation-for="Input.Type"></span>
    </div>

    <div>
        <label asp-for="Input.Diet"></label>
        <input asp-for="Input.Diet" />
        <span asp-validation-for="Input.Diet"></span>
    </div>

    <div>
        <label asp-for="Input.AdultSize"></label>
        <input asp-for="Input.AdultSize" type="number" step="0.1" />
        <span asp-validation-for="Input.AdultSize"></span>
    </div>
    
    <div>
        <label asp-for="Input.ImageUrl"></label>
        <input asp-for="Input.ImageUrl" />
        <span asp-validation-for="Input.ImageUrl"></span>
    </div>
    
    <button type="submit">Créer</button>
</form>

<a asp-page="/Species">Retour</a>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}