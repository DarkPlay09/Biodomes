@page
@model SpeciesModel
@{
    ViewData["Title"] = "Species";
}

<div class="layout-width entity-list-page">
    @if (!string.IsNullOrWhiteSpace(Model.LastInsertedSpeciesName))
    {
        <div class="alert">
            Espèce ajoutée : <strong>@Model.LastInsertedSpeciesName</strong>
        </div>
    }

    <div class="entity-page-header">
        <h1 class="hero-title">Espèces</h1>
        <a class="action-button entity-page-header__action" asp-page="/Species/Add">+ Ajouter une nouvelle espèce</a>
    </div>

    <div class="entity-grid">
        @foreach (var card in Model.Cards)
        {
            <partial name="Cards/_CatalogCard" model="card" />
        }
    </div>
</div>

