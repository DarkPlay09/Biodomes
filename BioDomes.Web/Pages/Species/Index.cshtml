@page
@model SpeciesModel
@{
    ViewData["Title"] = "Species";
}

<div class="layout-width species-list-page">
    @if (!string.IsNullOrWhiteSpace(Model.LastInsertedSpeciesName))
    {
        <div class="alert">
            Espèce ajoutée : <strong>@Model.LastInsertedSpeciesName</strong>
        </div>
    }

    <div class="species-page-header">
        <h1 class="hero-title">Espèces</h1>
        <a class="action-button species-page-header__action" asp-page="/Species/Add">+ Ajouter une nouvelle espèce</a>
    </div>

    <div class="species-grid">
        @foreach (var s in Model.SpeciesList)
        {
            <partial name="Species/_SpeciesCard" model="s"/>
        }
    </div>
</div>
