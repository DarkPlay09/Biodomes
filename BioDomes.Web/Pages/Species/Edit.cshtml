@page "/species/{slug:kebab:speciesSlug}"
@model BioDomes.Web.Pages.Species.EditModel

<div class="layout-width">
    <section class="species-form-page">
        <div class="species-form-page__intro">
            <span class="hero-badge">
                <span class="hero-badge-dot"></span>
                Modification
            </span>
            <h1 class="hero-title">Modifier une espèce</h1>
        </div>

        <div class="species-form-card">
            <form method="post" enctype="multipart/form-data" class="species-form">
                <div asp-validation-summary="ModelOnly" class="species-form__summary"></div>

                <partial name="Species/_SpeciesForm" model="new SpeciesFormViewModel
                 {
                     Input = Model.Input,
                     ClassificationOptions = Model.ClassificationOptions,
                     DietOptions = Model.DietOptions  
                 }"/>

                <div class="species-form__actions">
                    <a asp-page="/Species" class="species-form__back">Retour</a>
                    <button type="submit" class="action-button">Enregistrer</button>
                </div>
            </form>
        </div>
    </section>
</div>


<a asp-page="/Species">Retour à la liste</a>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
