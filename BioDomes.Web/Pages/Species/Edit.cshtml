@page "/species/{slug:kebab:speciesSlug}"
@model BioDomes.Web.Pages.Species.EditModel

@{
    Layout = "/Pages/Shared/_DashboardLayout.cshtml";

    ViewData["Title"] = "Modifier une espèce";
    ViewData["DashboardTitle"] = "Modifier une espèce";
    ViewData["DashboardSubtitle"] = "Mets à jour les informations, caractéristiques et visuels d’une espèce du catalogue BioDomes.";
}

<div class="layout-width">
    <section class="entity-form-page">
        <div class="entity-form-card">
            <form method="post" enctype="multipart/form-data" class="entity-form">
                <input type="hidden" asp-for="ReturnUrl" />
                
                <div asp-validation-summary="ModelOnly" class="entity-form__summary"></div>
                
                @if (Model.ShowImpactWarning)
                {
                    <div class="entity-impact-warning">
                        <strong>Attention :</strong>
                        cette espèce est utilisée dans @Model.ImpactedBiomesCount biome(s).
                        Modifier son poids ou son régime alimentaire peut impacter ces biomes.
                    </div>
                }

                <partial name="Species/_SpeciesForm" model="new SpeciesFormViewModel { Input = Model.Input, ClassificationOptions = Model.ClassificationOptions, DietOptions = Model.DietOptions, CurrentImagePath = Model.CurrentImagePath, CurrentImageFileName = string.IsNullOrWhiteSpace(Model.CurrentImagePath) ? null : System.IO.Path.GetFileName(Model.CurrentImagePath) }"/>

                <div class="entity-form__actions">
                    <a href="@Model.SafeReturnUrl" class="entity-form__back">Retour</a>
                    <button type="submit" class="action-button">Enregistrer</button>
                </div>
                
                <p class="entity-form__required-note">
                    Les champs marqués d’un <span class="entity-form__required" aria-hidden="true">*</span> sont obligatoires.
                </p>
            </form>
        </div>
    </section>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/shared/entity-file-upload.js" asp-append-version="true"></script>
}

