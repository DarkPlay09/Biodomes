@page "/species/details/{slug}"
@model BioDomes.Web.Pages.Species.DetailsModel

@{
    Layout = "/Pages/Shared/_DashboardLayout.cshtml";

    ViewData["Title"] = Model.SpeciesDetails.Name;
    ViewData["DashboardTitle"] = "Fiche espèce détaillée";
    ViewData["DashboardSubtitle"] = "Consulte les informations principales de cette espèce.";
    
    var currentUrl = $"{ViewContext.HttpContext.Request.Path}{ViewContext.HttpContext.Request.QueryString}";
}

<section class="species-details">
    <nav class="species-details-breadcrumb" aria-label="Fil d'Ariane">
        <a asp-page="./Index">Espèces</a>
        <span>›</span>
        <span>@Model.SpeciesDetails.ClassificationLabel</span>
        <span>›</span>
        <strong>@Model.SpeciesDetails.Name</strong>
    </nav>

    <div class="species-details-layout">
        <article class="species-details-image-card">
            <img src="@Model.SpeciesDetails.ImagePath"
                 alt="Image de @Model.SpeciesDetails.Name" />

            <div class="species-details-badges">
                <span class="species-details-badge @Model.SpeciesDetails.VisibilityCssClass">
                    @Model.SpeciesDetails.VisibilityLabel
                </span>
            </div>
        </article>

        <article class="species-details-content">
            <header class="species-details-header">
                <h2>@Model.SpeciesDetails.Name</h2>
            </header>

            <div class="species-details-stats">
                <div class="species-details-stat">
                    <img class="species-details-stat__icon" src="~/images/species/icons/category.png" alt="Icon classification" />
                    <small>Classification</small>
                    <strong>@Model.SpeciesDetails.ClassificationLabel</strong>
                </div>

                <div class="species-details-stat">
                    <img class="species-details-stat__icon" src="~/images/species/icons/cutlery.png" alt="Icon alimentation" />
                    <small>Régime</small>
                    <strong>@Model.SpeciesDetails.DietLabel</strong>
                </div>

                <div class="species-details-stat">
                    <img class="species-details-stat__icon" src="~/images/species/icons/height.png" alt="Icon taille" />
                    <small>Taille adulte</small>
                    <strong>@Model.SpeciesDetails.AdultSizeLabel</strong>
                </div>

                <div class="species-details-stat">
                    <img class="species-details-stat__icon" src="~/images/species/icons/weight.png" alt="Icon poids" />
                    <small>Poids</small>
                    <strong>@Model.SpeciesDetails.WeightLabel</strong>
                </div>

                <div class="species-details-stat">
                    <img class="species-details-stat__icon" src="~/images/species/icons/visibility.png" alt="Icon visibilité" />
                    <small>Visibilité</small>
                    <strong>@Model.SpeciesDetails.VisibilityLabel</strong>
                </div>

                <div class="species-details-stat">
                    <img class="species-details-stat__icon" src="~/images/species/icons/user.png" alt="Icon créateur" />
                    <small>Créateur</small>
                    <strong>@Model.SpeciesDetails.OwnerName</strong>
                </div>
            </div>
            
            @if (Model.SpeciesDetails.IsOwner)
            {
                <div class="species-details-actions">
                    <a asp-page="./Edit"
                       asp-route-slug="@Model.SpeciesDetails.Slug"
                       asp-route-returnUrl="@currentUrl"
                       class="species-details-edit-button">
                        Modifier la fiche
                    </a>
                </div>
            }
        </article>
    </div>
</section>