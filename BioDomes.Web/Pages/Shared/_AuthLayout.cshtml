<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - BioDomes</title>
    <link rel="icon" type="image/png" href="~/images/logo_biodomes.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<main class="auth-page">
    <section class="auth-visual">
        <div class="auth-visual__overlay"></div>

        <div class="auth-visual__content">
            <a asp-page="/Index"
               class="auth-brand"
               aria-label="Retour à la page d'accueil BioDomes">
                <img src="~/images/logo_biodomes.png"
                     alt="Logo BioDomes"
                     class="auth-brand__logo" />
                <span class="auth-brand__name">BioDomes</span>
            </a>

            <div class="auth-hero">
                <h1>@Html.Raw(ViewData["AuthHeroTitle"])</h1>
                <p>@ViewData["AuthHeroText"]</p>
            </div>
        </div>
    </section>

    <section class="auth-panel">
        <div class="auth-card">

            <a asp-page="/Index"
               class="auth-card__mobile-brand"
               aria-label="Retour à la page d'accueil BioDomes">
                <img src="~/images/logo_biodomes.png"
                     alt="Logo BioDomes"
                     class="auth-card__mobile-logo" />
                <span>BioDomes</span>
            </a>

            <header class="auth-card__header">
                <h2>@ViewData["AuthPageTitle"]</h2>
                <p>@ViewData["AuthPageSubtitle"]</p>
            </header>

            @RenderBody()
        </div>
    </section>
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>