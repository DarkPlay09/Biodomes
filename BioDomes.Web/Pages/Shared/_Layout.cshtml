<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - BioDomes : Terrarium Zero</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/images/logo_biodomes.png" />
</head>
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
}
<body>
<div class="site-shell">
    <header class="site-header">
        <div class="layout-width">
            <div class="header-row">
                <a class="brand-block" asp-area="" asp-page="/Index">
                    <img class="brand-logo" src="~/images/logo_biodomes.png" alt="Logo BioDomes"/>
                    <span class="brand-text">BioDomes</span>
                </a>
                
                <nav class="main-navigation">
                    <a class="nav-entry @(currentPage == "/Index" ? "nav-entry--active" : "")" asp-area="" asp-page="/Index">Accueil</a>
                    @if(User.Identity?.IsAuthenticated == true)
                    {
                        <a class="nav-entry @(currentPage?.StartsWith("/Biomes") == true ? "nav-entry--active" : "")" asp-area="" asp-page="/Biome/Index">Biomes</a>
                        <a class="nav-entry @(currentPage?.StartsWith("/Species") == true ? "nav-entry--active" : "")" asp-area="" asp-page="/Species/Index">Espèces</a>
                        <a class="nav-entry @(currentPage?.StartsWith("/Equipment") == true ? "nav-entry--active" : "")" asp-area="" asp-page="/Equipment/Index">Équipments</a>
                    }
                    else
                    {
                        <a class="nav-entry" href="#">Il faudrait ajouter des trucs mais on verra plus tard hahaha</a>
                    }
                </nav>
                
                <div class="header-actions">
                    <partial name="_LoginPartial" />
                </div>

                
                <button class="menu-toggle" type="button" id="menuToggle" aria-label="Ouvrir le menu">
                    ☰
                </button>
            </div>
        </div>
    </header>
    
    <div class="mobile-menu-overlay" id="mobileMenuOverlay"></div>

    <aside class="mobile-menu-panel" id="mobileMenuPanel">
        <button class="mobile-menu-close" type="button" id="menuClose" aria-label="Fermer le menu">×</button>

        <nav class="mobile-menu-nav">
            <a class="@(currentPage == "/Index" ? "mobile-menu-link--active" : "")" asp-page="/Index">Accueil</a>
            <a class="@(currentPage?.StartsWith("/Species") == true ? "mobile-menu-link--active" : "")" asp-page="/Species/Index">Espèces</a>
            <a href="#">Biomes</a>
            <a href="#">Équipements</a>
        </nav>

        <div class="mobile-menu-actions">
            <a class="action-link" asp-area="Identity" asp-page="/Account/Login">Connexion</a>
            <a class="action-button" asp-area="Identity" asp-page="/Account/Register">Inscription</a>
        </div>
    </aside>
    
    <main class="site-content" role="main">
        @RenderBody()
    </main>
</div>

<footer class="site-footer">
    <div class="footer-wrap">
        <div class="footer-grid">
            <div class="footer-column footer-brand">
                <a class="brand-block" asp-area="" asp-page="/Index">
                    <img class="brand-logo" src="~/images/logo_biodomes.png" alt="Logo BioDomes"/>
                    <span class="footer-title">BioDomes</span>
                </a>
                
                <p class="footer-description">
                    Plateforme de simulation de biomes et de gestion d’écosystèmes expérimentaux.
                </p>
            </div>
            
        
            <div class="footer-column">
                <h4 class="footer-title">Navigation</h4>
                <ul class="footer-list">
                    <li><a asp-area="" asp-page="/Index">Accueil</a></li>
                    <li><a asp-area="" asp-page="/Species">Espèces</a></li>
                    <li><a href="#">Biomes</a></li>
                    <li><a href="#">Équipements</a></li>
                </ul>
            </div>

            <div class="footer-column">
                <h4 class="footer-title">Légal</h4>
                <ul class="footer-list">
                    <li><a href="/Contact">Contact</a></li>
                    <li><a href="/Privacy">Confidentialité</a></li>
                </ul>
            </div>
        </div>
        
        <div class="footer-bottom">
            <p>© 2026 BioDomes - Terrarium Zero. Tous droits réservés.</p>
            <p>Projet académique de développement web</p>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
