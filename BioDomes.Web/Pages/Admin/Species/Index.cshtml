@page "/admin/species"
@model BioDomes.Web.Pages.Admin.Species.IndexModel

@{
    Layout = "/Pages/Shared/_DashboardLayout.cshtml";

    ViewData["Title"] = "Validation des espèces";
    ViewData["DashboardTitle"] = "Validation des espèces";
    ViewData["DashboardSubtitle"] = "Gère la visibilité des espèces créées par les utilisateurs.";

    var visibilityAllSelected = string.IsNullOrWhiteSpace(Model.VisibilityFilter) ? "selected" : null;
    var visibilityPublicSelected = Model.VisibilityFilter == "public" ? "selected" : null;
    var visibilityPrivateSelected = Model.VisibilityFilter == "private" ? "selected" : null;

    var request = ViewContext.HttpContext.Request;
    var currentUrl = $"{request.PathBase}{request.Path}{request.QueryString}";
}

@functions {
    private string ResolveImageUrl(string? imagePath, string fallbackPath)
    {
        if (string.IsNullOrWhiteSpace(imagePath))
            return Url.Content(fallbackPath);

        var normalizedPath = imagePath
            .Replace("\\", "/")
            .Trim();

        if (normalizedPath.StartsWith("~/"))
            return Url.Content(normalizedPath);

        return Url.Content("~/" + normalizedPath.TrimStart('/'));
    }
}

<section class="catalog-page">
    <form method="get" class="catalog-filter-card">
        <div class="catalog-filter-card__search">
            <label for="Search">Recherche</label>
            <input id="Search"
                   name="Search"
                   value="@Model.Search"
                   type="search"
                   placeholder="Rechercher par nom, créateur, classification ou régime..." />
        </div>

        <div class="catalog-filter-card__select">
            <label for="ClassificationFilter">Classification</label>
            <select id="ClassificationFilter" name="ClassificationFilter">
                <option value="">Toutes</option>

                @foreach (var classification in Model.ClassificationOptions)
                {
                    var selected = Model.ClassificationFilter == classification ? "selected" : null;

                    <option value="@classification" selected="@selected">
                        @Model.FormatClassification(classification)
                    </option>
                }
            </select>
        </div>

        <div class="catalog-filter-card__select">
            <label for="DietFilter">Régime</label>
            <select id="DietFilter" name="DietFilter">
                <option value="">Tous</option>

                @foreach (var diet in Model.DietOptions)
                {
                    var selected = Model.DietFilter == diet ? "selected" : null;

                    <option value="@diet" selected="@selected">
                        @Model.FormatDiet(diet)
                    </option>
                }
            </select>
        </div>

        <div class="catalog-filter-card__select">
            <label for="VisibilityFilter">Visibilité</label>
            <select id="VisibilityFilter" name="VisibilityFilter">
                <option value="" selected="@visibilityAllSelected">Toutes</option>
                <option value="public" selected="@visibilityPublicSelected">Disponibles</option>
                <option value="private" selected="@visibilityPrivateSelected">Non visibles</option>
            </select>
        </div>

        <div class="catalog-filter-card__actions">
            <button type="submit" class="dashboard-btn dashboard-btn--primary">
                Filtrer
            </button>

            <a asp-page="./Index" class="dashboard-btn dashboard-btn--ghost">
                Réinitialiser
            </a>
        </div>
    </form>

    @if (Model.SpeciesList.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state__icon" aria-hidden="true">+</div>

            <h3>Aucune espèce trouvée</h3>

            <p>
                Aucune espèce créée par un utilisateur ne correspond aux filtres sélectionnés.
            </p>
        </div>
    }
    else
    {
        <div class="admin-entity-list">
            @foreach (var species in Model.SpeciesList)
            {
                var statusClass = species.IsPublicAvailable
                    ? "admin-entity-card__status--visible"
                    : "admin-entity-card__status--hidden";

                var statusLabel = species.IsPublicAvailable
                    ? "Disponible"
                    : "Non visible";

                var actionButtonClass = species.IsPublicAvailable
                    ? "admin-entity-card__button admin-entity-card__button--hidden"
                    : "admin-entity-card__button admin-entity-card__button--visible";

                var imageSrc = ResolveImageUrl(
                    species.ImagePath,
                    "~/uploads/species/noImageSpecie.png"
                );

                <article class="admin-entity-card">
                    <div class="admin-entity-card__image">
                        <img src="@imageSrc" alt="Image de @species.Name" />
                    </div>

                    <div class="admin-entity-card__content">
                        <div>
                            <p class="admin-entity-card__eyebrow">
                                @species.ClassificationLabel
                            </p>

                            <h3>@species.Name</h3>

                            <dl class="admin-entity-card__meta">
                                <div>
                                    <dt>Régime</dt>
                                    <dd>@species.DietLabel</dd>
                                </div>

                                <div>
                                    <dt>Créateur</dt>
                                    <dd>@species.CreatorName</dd>
                                </div>

                                <div>
                                    <dt>Visibilité</dt>
                                    <dd>@species.VisibilityLabel</dd>
                                </div>
                            </dl>
                        </div>

                        <div class="admin-entity-card__actions">
                            <a asp-page="/Species/Details"
                               asp-route-slug="@species.Slug"
                               asp-route-returnUrl="@currentUrl"
                               class="admin-entity-card__button admin-entity-card__button--ghost">
                                Voir la fiche
                            </a>

                            <form method="post"
                                  asp-page-handler="SetVisibility"
                                  asp-route-slug="@species.Slug"
                                  asp-route-makePublic="@(!species.IsPublicAvailable)"
                                  asp-route-Search="@Model.Search"
                                  asp-route-ClassificationFilter="@Model.ClassificationFilter"
                                  asp-route-DietFilter="@Model.DietFilter"
                                  asp-route-VisibilityFilter="@Model.VisibilityFilter"
                                  asp-route-PageNumber="@Model.PageNumber">
                                <button type="submit" class="@actionButtonClass">
                                    @(species.IsPublicAvailable ? "Rendre non visible" : "Rendre disponible")
                                </button>
                            </form>
                        </div>
                    </div>
                </article>
            }
        </div>
    }

    @if (Model.TotalPages > 1)
    {
        <footer class="catalog-pagination">
            <div>
                Page <strong>@Model.PageNumber</strong> sur <strong>@Model.TotalPages</strong>
            </div>

            <nav aria-label="Pagination des espèces à valider">
                @if (Model.PageNumber <= 1)
                {
                    <span class="catalog-pagination__link catalog-pagination__link--disabled">
                        Précédent
                    </span>
                }
                else
                {
                    <a asp-page="./Index"
                       asp-route-Search="@Model.Search"
                       asp-route-ClassificationFilter="@Model.ClassificationFilter"
                       asp-route-DietFilter="@Model.DietFilter"
                       asp-route-VisibilityFilter="@Model.VisibilityFilter"
                       asp-route-PageNumber="@(Model.PageNumber - 1)"
                       class="catalog-pagination__link">
                        Précédent
                    </a>
                }

                @foreach (var pageNumber in Model.VisiblePages)
                {
                    var activeClass = pageNumber == Model.PageNumber
                        ? "catalog-pagination__link--active"
                        : "";

                    <a asp-page="./Index"
                       asp-route-Search="@Model.Search"
                       asp-route-ClassificationFilter="@Model.ClassificationFilter"
                       asp-route-DietFilter="@Model.DietFilter"
                       asp-route-VisibilityFilter="@Model.VisibilityFilter"
                       asp-route-PageNumber="@pageNumber"
                       class="catalog-pagination__link @activeClass">
                        @pageNumber
                    </a>
                }

                @if (Model.PageNumber >= Model.TotalPages)
                {
                    <span class="catalog-pagination__link catalog-pagination__link--disabled">
                        Suivant
                    </span>
                }
                else
                {
                    <a asp-page="./Index"
                       asp-route-Search="@Model.Search"
                       asp-route-ClassificationFilter="@Model.ClassificationFilter"
                       asp-route-DietFilter="@Model.DietFilter"
                       asp-route-VisibilityFilter="@Model.VisibilityFilter"
                       asp-route-PageNumber="@(Model.PageNumber + 1)"
                       class="catalog-pagination__link">
                        Suivant
                    </a>
                }
            </nav>
        </footer>
    }
</section>